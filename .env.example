# Variables de entorno para StudyFlow Backend

# Base de datos PostgreSQL
# Puedes usar Supabase: rellena las variables SUPABASE_* o DATABASE_* (no subas claves a git)
SUPABASE_DATABASE_URL=
SUPABASE_DB_USER=
SUPABASE_DB_PASSWORD=
SUPABASE_DB_HOST=
SUPABASE_DB_PORT=5432
SUPABASE_DB_NAME=studyflow

# Alternativa: URL JDBC completa o variables genéricas
DATABASE_URL=jdbc:postgresql://localhost:5432/studyflow
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=postgres

# API Gemini (Google)
GEMINI_API_KEY=tu_clave_de_gemini_aqui

# Server
SERVER_PORT=8080

# Environment
ENVIRONMENT=development
